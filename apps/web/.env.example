# apps/web runtime environment. Copy to .env and fill in. Every key here is
# loaded by the app or by Prisma at runtime; there are no unused keys.

# --- App (required) ---
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000

# --- Auth secret (required): any long random string ---
BETTER_AUTH_SECRET=change-me-generate-a-long-random-string

# --- Database (required): Supabase ---
# DATABASE_URL = transaction pooler (6543, pgbouncer=true) for the app runtime.
# DIRECT_URL   = session pooler (5432) for Prisma migrations.
# Percent-encode special characters in the password (for example @ becomes %40).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# --- Google OAuth (optional): blank hides the "Continue with Google" button ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Resend email (optional): blank logs emails to the server console ---
RESEND_API_KEY=
EMAIL_FROM=Fiberarticle <noreply@fiberarticle.com>
