# Database: a PostgreSQL instance with the pgvector extension.
# We use Supabase (session pooler). Percent-encode special characters in the
# password when putting it in this URL (for example @ becomes %40).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Web app that issues JWTs (Better Auth)
WEB_URL=http://localhost:3000

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Master secret for AES-GCM encryption of stored provider keys.
# Any long random string; it is hashed to a 256-bit key.
KEY_ENCRYPTION_SECRET=change-me-long-random-string

# Fiberarticle AI managed mode (OpenCode Zen, white-labeled).
# With an empty key, keyless free-tier Zen models are used.
FIBERARTICLE_AI_API_KEY=
FIBERARTICLE_AI_BASE_URL=https://opencode.ai/zen/v1
# Max-reasoning model (used when the user keeps reasoning on) and a fast
# non-reasoning model (used when they turn it off).
FIBERARTICLE_AI_MODEL=deepseek-v4-flash-free
FIBERARTICLE_AI_FAST_MODEL=mimo-v2.5-free

# Unpaywall polite pool email
CONTACT_EMAIL=abdulateeb5932@gmail.com

